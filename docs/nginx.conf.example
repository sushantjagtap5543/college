# GEOSUREPATH - Production Nginx Configuration Example
# Location: /etc/nginx/sites-available/geosurepath

server {
    listen 80;
    server_name yourdomain.com; # Replace with your domain or IP

    # Redirect HTTP to HTTPS (uncomment after setting up SSL)
    # return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl;
    server_name yourdomain.com;

    # SSL configuration (Certbot recommended)
    # ssl_certificate /etc/letsencrypt/live/yourdomain.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/yourdomain.com/privkey.pem;

    # 1. Frontend Static Files
    location / {
        root /var/www/geosurepath/frontend/dist;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # 2. Main Backend API
    location /api {
        proxy_pass http://localhost:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    # 3. Socket.IO (WebSockets)
    location /socket.io {
        proxy_pass http://localhost:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
    }

    # 4. Traccar REST API Proxy
    location /traccar/api {
        proxy_pass http://localhost:8082/api;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 5. Traccar Webhook
    location /api/traccar/webhooks {
        proxy_pass http://localhost:8080/api/traccar/webhooks;
        proxy_set_header Host $host;
    }
}
