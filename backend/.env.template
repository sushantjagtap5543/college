# GEOSUREPATH - Production Environment Template
# Copy this file to .env and fill in your actual credentials.

# --- SERVER CONFIG ---
PORT=8080
NODE_ENV=production

# --- DATABASE (POSTGRES) ---
POSTGRES_USER=gps_admin
POSTGRES_PASSWORD=your_secure_db_password
DB_HOST=localhost
POSTGRES_DB=gps_saas
DB_PORT=5432

# --- CACHE (REDIS) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- EMAIL (SMTP) ---
# Use real credentials from Hostinger, Gmail, or SendGrid
SMTP_HOST=smtp.yourserver.com
SMTP_PORT=587
SMTP_USER=support@geosurepath.com
SMTP_PASS=your_email_app_password

# --- SMS/WHATSAPP (TWILIO) ---
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# --- FRONTEND (VITE) ---
# Set this for your production domain
VITE_API_BASE=http://your_server_ip:8080

# --- GOOGLE DRIVE ARCHIVAL ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_BACKUP_FOLDER_ID=your_google_drive_folder_id_here
